<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <base target="_top">
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  
  <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
  
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
  
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.0.0"></script>
  
  <script src='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.js'></script>
  
  <style>
    :root {
      --bg-page: #f4f1ea; --text-pri: #3e2723; --text-sec: #8d6e63;
      --accent: #a1887f; --highlight: #6d4c41; --card-bg: #ffffff;
      --border-color: #d7ccc8; --input-bg: #ffffff; --input-text: #3e2723;
      --dropdown-bg: #ffffff; --hover-item: #f5f5f5;
      --shadow: 0 8px 24px rgba(62, 39, 35, 0.08);
      --st-sol: #1e88e5; --st-ent: #43a047; --st-pen: #ffb300; 
    }
    body.dark-mode {
      --bg-page: #1a1a1a; --text-pri: #e0e0e0; --text-sec: #bdbdbd;
      --highlight: #a1887f; --card-bg: #2d2d2d; --border-color: #444444;
      --input-bg: #333333; --input-text: #ffffff; --dropdown-bg: #333333;
      --hover-item: #444444; --shadow: 0 8px 24px rgba(0, 0, 0, 0.5);
    }
    body { background-color: var(--bg-page); color: var(--text-pri); font-family: 'Segoe UI', system-ui, sans-serif; transition: 0.3s; overflow-x: hidden; }
    
    .text-uppercase-force { text-transform: uppercase !important; }

    .layout-wrapper { display: flex; min-height: 100vh; }
    .sidebar {
        width: 220px; background-color: var(--card-bg); border-right: 1px solid var(--border-color);
        display: flex; flex-direction: column; align-items: center; padding-top: 20px; transition: width 0.3s;
        z-index: 100; position: fixed; top: 0; bottom: 0; left: 0;
    }
    .main-content { margin-left: 220px; width: calc(100% - 220px); padding: 30px; }
    .nav-btn {
        width: 100%; padding: 15px 20px; background: transparent; border: none;
        color: var(--text-sec); text-align: left; display: flex; align-items: center;
        cursor: pointer; transition: 0.2s; white-space: nowrap; overflow: hidden;
    }
    .nav-btn i { font-size: 1.5rem; min-width: 40px; text-align: center; }
    .nav-btn span { opacity: 1; transition: opacity 0.2s; font-weight: 600; margin-left: 10px; }
    .nav-btn:hover { background-color: var(--hover-item); color: var(--highlight); }
    .nav-btn.active { background-color: var(--highlight); color: #fff; }
    
    .custom-dropdown-btn {
        background-color: var(--input-bg); border: 1px solid var(--border-color); color: var(--input-text);
        text-align: left; display: flex; justify-content: space-between; align-items: center;
        width: 100%; padding: 10px 15px; border-radius: 10px; font-weight: 500; transition: 0.2s;
        text-transform: uppercase;
    }
    .custom-dropdown-btn:hover { border-color: var(--highlight); }
    .dropdown-menu-custom {
        background-color: var(--dropdown-bg); border: 1px solid var(--border-color);
        padding: 10px; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        max-height: 400px; width: 100%; min-width: 250px; z-index: 1050;
    }
    .dropdown-search {
        background-color: var(--bg-page); border: 1px solid var(--border-color); color: var(--input-text);
        border-radius: 6px; padding: 8px; margin-bottom: 10px; width: 100%;
        text-transform: uppercase;
    }
    .dropdown-search:focus { outline: none; border-color: var(--highlight); }
    .dropdown-list-container { max-height: 250px; overflow-y: auto; }
    .dropdown-list-container::-webkit-scrollbar { width: 6px; }
    .dropdown-list-container::-webkit-scrollbar-thumb { background-color: var(--highlight); border-radius: 3px; }
    .dropdown-item-custom {
        display: flex; align-items: center; padding: 8px; border-radius: 6px;
        cursor: pointer; color: var(--input-text); transition: 0.1s;
        text-transform: uppercase; font-size: 0.85rem;
    }
    .dropdown-item-custom:hover { background-color: var(--hover-item); }
    .form-check-input {
        width: 18px; height: 18px; margin-right: 10px; cursor: pointer;
        background-color: var(--bg-page); border-color: var(--border-color);
    }
    .form-check-input:checked { background-color: var(--highlight); border-color: var(--highlight); }
    
    .card-custom { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 16px; box-shadow: var(--shadow); }
    
    .oficina-selector {
        background-color: var(--input-bg); color: var(--input-text); border: 2px solid var(--border-color);
        font-weight: 700; border-radius: 10px; padding: 10px; width: 100%; cursor: pointer;
    }
    .oficina-selector option { background-color: var(--input-bg); color: var(--input-text); }
    
    .kpi-card { 
      background: var(--card-bg); border-radius: 16px; padding: 25px 20px; 
      box-shadow: var(--shadow); text-align: center; border: 1px solid var(--border-color); position: relative;
    }
    .kpi-card.blue { border-left: 5px solid var(--st-sol); }
    .kpi-card.green { border-left: 5px solid var(--st-ent); }
    .kpi-card.yellow { border-left: 5px solid var(--st-pen); }
    .kpi-label { font-size: 0.8rem; color: var(--text-sec); font-weight: 700; text-transform: uppercase; margin-bottom: 5px; }
    .kpi-val { font-size: 2.5rem; font-weight: 800; color: var(--text-pri); }
    
    .viz-box { 
      background: var(--card-bg); border-radius: 16px; padding: 25px; 
      box-shadow: var(--shadow); border: 1px solid var(--border-color);
      position: relative; height: 100%; min-height: 550px; display: flex; flex-direction: column;
    }
    .chart-container { flex: 1; position: relative; }
    .chart-header { font-weight: 700; color: var(--text-sec); text-align: center; text-transform: uppercase; font-size: 0.9rem; margin-bottom: 15px; }
    
    .table-box { flex: 1; overflow-y: auto; }
    .custom-table { width: 100%; border-collapse: separate; border-spacing: 0; }
    .custom-table th { 
        background-color: var(--highlight); color: #fff; position: sticky; top: 0; 
        padding: 12px; font-weight: 600; font-size: 0.85rem; text-transform: uppercase; border: none; z-index: 10;
    }
    .custom-table td { padding: 12px; font-size: 0.9rem; color: var(--text-pri); border-bottom: 1px solid var(--border-color); vertical-align: middle; }
    .custom-table tbody tr.parent-row:hover td { background-color: var(--hover-item); cursor: pointer; }
    
    .sim-input {
        width: 60px; padding: 4px; border: 1px solid var(--border-color); border-radius: 6px;
        background-color: var(--bg-page); color: var(--text-pri); text-align: center;
        font-weight: bold; font-size: 0.85rem;
    }
    .sim-input:focus { outline: none; border-color: var(--highlight); background-color: var(--card-bg); }
    .sim-val-pen { font-weight: 800; color: var(--st-pen); font-size: 0.9rem; }

    .status-badge { padding: 5px 12px; border-radius: 20px; font-size: 0.75rem; font-weight: 700; border: 1px solid; display: inline-block; text-transform: uppercase; }
    .st-prod { background: rgba(33, 150, 243, 0.1); color: #2196F3; border-color: #2196F3; } 
    .st-montagem { background: rgba(156, 39, 176, 0.1); color: #9C27B0; border-color: #9C27B0; }
    .st-planejamento { background: rgba(233, 30, 99, 0.1); color: #E91E63; border-color: #E91E63; }
    .st-aguardando { background: rgba(253, 126, 20, 0.1); color: #fd7e14; border-color: #fd7e14; }
    .st-pendente { background: rgba(255, 193, 7, 0.1); color: #ffc107; border-color: #ffc107; }
    .st-estoque { background: rgba(0, 188, 212, 0.1); color: #00BCD4; border-color: #00BCD4; }
    .st-orcamento { background: rgba(121, 85, 72, 0.1); color: #795548; border-color: #795548; }
    .st-nao-aut { background: rgba(220, 53, 69, 0.1); color: #dc3545; border-color: #dc3545; }
    .st-arquivado { background: rgba(108, 117, 125, 0.1); color: #6c757d; border-color: #6c757d; }
    .st-finalizado { background: rgba(25, 135, 84, 0.1); color: #198754; border-color: #198754; }
    .st-default { background: rgba(158, 158, 158, 0.1); color: #9E9E9E; border-color: #9E9E9E; }

    .prio-badge { display: inline-flex; align-items: center; justify-content: center; width: 30px; height: 30px; border-radius: 50%; font-weight: bold; border: 1px solid; }
    .prio-1 { background: rgba(220, 53, 69, 0.1); color: #dc3545; border-color: #dc3545; }
    .prio-2 { background: rgba(253, 126, 20, 0.1); color: #fd7e14; border-color: #fd7e14; }
    .prio-3 { background: rgba(255, 193, 7, 0.1); color: #ffc107; border-color: #ffc107; }
    .prio-4 { background: rgba(25, 135, 84, 0.1); color: #198754; border-color: #198754; }
    .prio-5 { background: rgba(13, 110, 253, 0.1); color: #0d6efd; border-color: #0d6efd; }
    .prio-default { color: var(--text-sec); border-color: var(--border-color); }

    .date-alert { color: #dc3545 !important; font-weight: 800 !important; }

    .detail-row td { padding: 0 !important; border: none !important; }
    .sub-table th { background: transparent !important; color: var(--text-sec); font-size: 0.75rem; border-bottom: 2px solid var(--border-color); }
    .sub-table td { font-size: 0.8rem; color: var(--text-pri); padding: 8px; vertical-align: middle; }
    
    .parent-row .bi-chevron-down { transition: transform 0.3s; }
    .parent-row[aria-expanded="true"] .bi-chevron-down { transform: rotate(180deg); }

    .pagination-container { display: flex; justify-content: space-between; align-items: center; padding: 15px; border-top: 1px solid var(--border-color); }
    .pagination-btn { background: var(--card-bg); border: 1px solid var(--border-color); color: var(--text-pri); padding: 5px 15px; border-radius: 8px; cursor: pointer; }
    .pagination-btn:disabled { opacity: 0.5; cursor: not-allowed; }
    .pagination-btn:hover:not(:disabled) { background-color: var(--hover-item); border-color: var(--highlight); }

    .loader-overlay { position: fixed; top:0; left:0; width:100%; height:100%; background: var(--bg-page); display:flex; flex-direction:column; justify-content:center; align-items:center; z-index:9999; }
    .btn-action {
        width: 40px; height: 40px; border-radius: 50%; border: 1px solid var(--border-color);
        background: var(--card-bg); color: var(--text-pri); display: flex; justify-content: center; align-items: center; cursor: pointer;
    }
    .btn-action:hover { background: var(--highlight); color: #fff; border-color: var(--highlight); }
    .view-section { display: none; height: 100%; }
    .view-section.active { display: block; animation: fadeIn 0.4s; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    .fc { --fc-border-color: var(--border-color); --fc-page-bg-color: var(--card-bg); --fc-neutral-bg-color: var(--bg-page); --fc-list-event-hover-bg-color: var(--hover-item); color: var(--text-pri); }
    .fc-toolbar-title { font-size: 1.2rem !important; text-transform: uppercase; color: var(--text-pri); }
    .fc-button-primary { background-color: var(--highlight) !important; border-color: var(--highlight) !important; }
    .fc-button-primary:hover { background-color: var(--text-sec) !important; border-color: var(--text-sec) !important; }
    .fc-daygrid-day-number { color: var(--text-pri); text-decoration: none; }
    .fc-col-header-cell-cushion { color: var(--text-sec); text-decoration: none; text-transform: uppercase; font-size: 0.8rem; }
    
    .procon-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; margin-bottom: 20px; transition: transform 0.2s, box-shadow 0.2s; overflow: hidden; }
    .procon-card:hover { transform: translateY(-3px); box-shadow: var(--shadow); }
    .procon-header { padding: 15px; cursor: pointer; display: flex; flex-direction: column; gap: 8px; }
    .header-totals { display: flex; flex-wrap: wrap; gap: 8px; font-size: 0.75rem; margin-top: 5px; padding-top: 5px; border-top: 1px dashed var(--border-color); }
    .h-badge { padding: 4px 8px; border-radius: 4px; font-weight: 700; background: rgba(0,0,0,0.03); border: 1px solid rgba(0,0,0,0.1); text-transform: uppercase; }
    .origin-badge { font-size: 0.7rem; font-weight: 800; letter-spacing: 0.5px; padding: 3px 8px; border-radius: 4px; display: inline-block; width: fit-content; text-transform: uppercase; }
    .date-badge { font-size: 0.75rem; font-weight: 700; color: var(--text-sec); margin-left: auto; display: flex; align-items: center; gap: 4px; }
    .origin-sede { background-color: #3e2723; color: #fff; }
    .origin-regional { background-color: #8d6e63; color: #fff; }
    .procon-title { font-weight: 700; color: var(--text-pri); font-size: 1rem; line-height: 1.3; text-transform: uppercase; }
    .procon-meta { display: flex; justify-content: space-between; align-items: center; margin-top: 5px; font-size: 0.85rem; color: var(--text-sec); text-transform: uppercase; }
    .procon-details { background-color: var(--hover-item); border-top: 1px solid var(--border-color); padding: 0; }
    .procon-item-row { padding: 15px; border-bottom: 1px solid var(--border-color); }
    .procon-item-row:last-child { border-bottom: none; }
    .detail-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; font-size: 0.85rem; margin-bottom: 10px; }
    .detail-item strong { display: block; color: var(--text-sec); font-size: 0.7rem; text-transform: uppercase; }
    .detail-item span { color: var(--text-pri); font-weight: 600; text-transform: uppercase; }
    .qty-badge { display: inline-flex; flex-direction: column; align-items: center; justify-content: center; padding: 5px; border-radius: 6px; border: 1px solid var(--border-color); background: var(--card-bg); min-width: 50px; flex: 1; }
    .qty-val { font-weight: 800; font-size: 1rem; }
    .qty-lbl { font-size: 0.6rem; text-transform: uppercase; color: var(--text-sec); }

    .post-it-container { position: relative; display: inline-flex; align-items: center; margin-left: 6px; vertical-align: middle; }
    .post-it-icon { color: #ffca28; font-size: 1.1rem; cursor: help; transition: transform 0.2s; filter: drop-shadow(1px 1px 1px rgba(0,0,0,0.2)); }
    .post-it-icon:hover { transform: scale(1.2); color: #ffb300; }
    .post-it-tooltip {
        visibility: hidden; opacity: 0; position: absolute; bottom: 140%; left: 50%;
        transform: translateX(-50%) translateY(10px); width: max-content; max-width: 280px;
        background: linear-gradient(135deg, #fff9c4 80%, #f0e68c 100%); color: #3e2723 !important;
        text-align: left; padding: 10px 14px; box-shadow: 3px 5px 15px rgba(0,0,0,0.3); z-index: 1060;
        font-size: 0.85rem; line-height: 1.4; border-radius: 2px 10px 10px 10px; border: 1px solid #e6c513;
        transition: all 0.2s ease-in-out; pointer-events: none; white-space: normal;
    }
    .post-it-tooltip::after {
        content: ""; position: absolute; top: 100%; left: 50%; margin-left: -6px; border-width: 6px;
        border-style: solid; border-color: #f0e68c transparent transparent transparent;
    }
    .post-it-container:hover .post-it-tooltip { visibility: visible; opacity: 1; transform: translateX(-50%) translateY(0); }

    .sortable-header { cursor: pointer; user-select: none; white-space: nowrap; transition: filter 0.2s; }
    .sortable-header:hover { filter: brightness(0.85); }
    .sort-icon { font-size: 0.8rem; margin-left: 4px; opacity: 0.5; transition: opacity 0.2s, transform 0.2s; }

    @keyframes slideDownFadIn { from { opacity: 0; transform: translateY(-30px); } to { opacity: 1; transform: translateY(0); } }
    .notif-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.6); backdrop-filter: blur(5px); z-index: 10500; display: none; align-items: center; justify-content: center; }
    .notif-box { background: var(--card-bg); width: 95%; max-width: 600px; max-height: 85vh; border-radius: 16px; display: flex; flex-direction: column; box-shadow: 0 15px 50px rgba(0,0,0,0.5); overflow: hidden; border: 1px solid var(--border-color); animation: slideDownFadIn 0.3s ease-out forwards; }
    .notif-header { padding: 20px; background: var(--highlight); color: #fff; display: flex; justify-content: space-between; align-items: center; }
    .notif-body { padding: 20px; overflow-y: auto; color: var(--text-pri); flex: 1; }
    .notif-footer { padding: 15px 20px; border-top: 1px solid var(--border-color); display: flex; justify-content: flex-end; gap: 10px; background: var(--bg-page); }
    
    .notif-item { border: 1px solid var(--border-color); border-radius: 10px; overflow: hidden; margin-bottom: 12px; }
    .notif-item:last-child { margin-bottom: 0; }
    .notif-item-header { padding: 15px; background: var(--hover-item); cursor: pointer; transition: background 0.2s; }
    .notif-item-header:hover { background: var(--bg-page); }
    .notif-item-header .bi-chevron-down { transition: transform 0.3s; }
    .notif-item-header[aria-expanded="true"] .bi-chevron-down { transform: rotate(180deg); }
    .notif-item-body { padding: 15px; border-top: 1px solid var(--border-color); background: var(--card-bg); }
    .notif-item-list { list-style: none; padding-left: 0; margin-bottom: 0; }
    .notif-item-list li { background: var(--bg-page); padding: 8px 12px; border-radius: 6px; margin-bottom: 5px; display: flex; justify-content: space-between; align-items: center; font-size: 0.85rem; border: 1px solid var(--border-color); }
  </style>
</head>
<body>

  <div id="loader" class="loader-overlay">
    <div class="spinner-border mb-3" role="status" style="width: 3rem; height: 3rem; color: var(--highlight); border-width: 4px;"></div>
    <h6 style="color: var(--text-sec); font-weight: 700; letter-spacing: 1px;">CARREGANDO...</h6>
  </div>

  <div class="layout-wrapper">
      <div class="sidebar">
          <div class="mb-4 d-flex align-items-center gap-3">
              <i class="bi bi-box-seam fs-1" style="color: var(--highlight);"></i>
              <div class="position-relative" style="cursor: pointer; transition: transform 0.2s;" onclick="openNotifications()" title="Entregas da Semana" onmouseover="this.style.transform='scale(1.1)'" onmouseout="this.style.transform='scale(1)'">
                  <i class="bi bi-bell-fill fs-4" style="color: var(--highlight);"></i>
                  <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger shadow" id="notifBadge" style="display:none; font-size: 0.6rem; border: 2px solid var(--card-bg);">0</span>
              </div>
          </div>

          <button class="nav-btn active" onclick="switchView('viewTable', this)"><i class="bi bi-table"></i> <span>Tabela</span></button>
          <button class="nav-btn" onclick="switchView('viewCalendar', this)"><i class="bi bi-calendar-event"></i> <span>Calendário</span></button>
          <button class="nav-btn" onclick="switchView('viewChart1', this)"><i class="bi bi-bar-chart-fill"></i> <span>Status</span></button>
          <button class="nav-btn" onclick="switchView('viewChart2', this)"><i class="bi bi-geo-alt-fill"></i> <span>Parceiros</span></button>
          <button class="nav-btn" onclick="switchView('viewChart3', this)"><i class="bi bi-boxes"></i> <span>Volume</span></button>
          <button class="nav-btn" onclick="switchView('viewProcon', this)"><i class="bi bi-building-gear"></i> <span>PROCON | TECH</span></button>
      </div>

      <div class="main-content">
          <div class="d-flex justify-content-between align-items-end mb-4">
            <div>
              <h2 class="fw-bold m-0" style="color: var(--text-pri);">DASHBOARD - MARCENARIA</h2>
              <p class="m-0 small" style="color: var(--text-sec);">Marcenaria & Serralheria</p>
            </div>
            <div class="d-flex gap-2 align-items-center">
              <button class="btn-action" onclick="refreshCurrent(true)" title="Atualizar dados (Forçar atualização do Cache)"><i class="bi bi-arrow-repeat fs-5"></i></button>
              <button class="btn-action" onclick="toggleTheme()" title="Modo Escuro"><i class="bi bi-moon-stars-fill fs-6" id="themeIcon"></i></button>
              <div class="ms-3 d-none d-md-block text-end"><span class="badge" style="background: rgba(128,128,128,0.1); color: var(--text-sec); border: 1px solid var(--border-color);"><i class="bi bi-clock me-1"></i> <span id="lastUpdate">...</span></span></div>
            </div>
          </div>

          <div id="mainSectionGroup">
              <div class="card card-custom mb-4">
                <div class="card-body p-4">
                  <div class="d-flex justify-content-between align-items-center mb-3">
                      <h6 class="fw-bold m-0" style="color: var(--highlight); text-transform: uppercase; font-size: 0.8rem;">
                          <i class="bi bi-funnel-fill me-2"></i>Filtros
                      </h6>
                      <div class="d-flex gap-2">
                          <button class="btn btn-sm btn-outline-danger rounded-pill px-3" onclick="resetFilters()">Limpar Todos</button>
                          
                          <div class="dropdown">
                              <button class="btn btn-sm text-white rounded-pill px-3 shadow-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" style="background-color: #d32f2f; border: none;" id="btnExportPDFMain">
                                  <i class="bi bi-file-earmark-pdf-fill me-1"></i>Gerar PDF
                              </button>
                              <ul class="dropdown-menu dropdown-menu-end shadow" style="font-size: 0.85rem; z-index: 9999;">
                                  <li><h6 class="dropdown-header fw-bold text-uppercase" style="color:var(--highlight)">Separado por Processo</h6></li>
                                  <li><a class="dropdown-item py-2" style="cursor: pointer;" onclick="exportToPDF(1)">Com Material e Dimensão</a></li>
                                  <li><a class="dropdown-item py-2" style="cursor: pointer;" onclick="exportToPDF(2)">Apenas Mobília (Soma as Quantidades)</a></li>
                                  <li><hr class="dropdown-divider"></li>
                                  <li><h6 class="dropdown-header fw-bold text-uppercase" style="color:var(--highlight)">Sem Processo (Consolidado)</h6></li>
                                  <li><a class="dropdown-item py-2" style="cursor: pointer;" onclick="exportToPDF(3)">Com Material e Dimensão</a></li>
